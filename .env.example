# Sui network: "testnet" (default), "mainnet", "devnet", or "localnet"
NEXT_PUBLIC_SUI_NETWORK=testnet

# Optional: dedicated RPC endpoint.
# Defaults to the public Sui fullnode for the chosen network.
# NEXT_PUBLIC_SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# Canonical URL for Open Graph / WhatsApp / Telegram link previews.
# Set this to your Vercel deployment URL (or custom domain) before deploying.
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Optional: host that serves /og.png without a redirect hop.
# Only needed if your primary domain redirects (apex → www or vice versa).
# NEXT_PUBLIC_ASSET_URL=https://your-app.vercel.app

# --- Admin dashboard (/admin) ----------------------------------------
# Long random string · server-only. Sign in at /admin after deploying.
# STAKEMATE_ADMIN_SECRET=

# --- Persistent storage (optional) -----------------------------------
# When set, agent registrations and user profiles persist across Vercel
# cold starts via Upstash Redis. Without it, state resets on each restart.
#
# Get free credentials at https://upstash.com (Redis → REST API).
# UPSTASH_REDIS_REST_URL=https://your-region-redis.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token-here

# --- Sui escrow (on-chain wagers) ------------------------------------
# Treasury address that receives settlement fees and treasury-mode wagers.
# NEXT_PUBLIC_SUI_TREASURY_ADDRESS=0x...
#
# On-chain escrow via the stakemate::escrow Move package.
# Publish with: sui client publish move/stakemate_escrow --gas-budget 200000000
# When both IDs are set, wagers lock in the on-chain Registry instead of a
# direct treasury transfer.
# NEXT_PUBLIC_SUI_ESCROW_PACKAGE_ID=0x...
# NEXT_PUBLIC_SUI_ESCROW_REGISTRY_ID=0x...

# Server-only: oracle keypair that signs match lifecycle transactions
# (create_match, settle_match, cancel_match). Sui Bech32 format: "suiprivkey..."
# Export with: sui keytool export --key-identity <address> --json
# STAKEMATE_ORACLE_PRIVATE_KEY=
